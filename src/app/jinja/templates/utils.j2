{# =================== File Header =================== #}
{% macro generate_file_header(filepath, tab) -%}
// Generated by: BlueprintCPP

/// @file {{ filepath }}
{%- endmacro %}


{# =================== Class Member H =================== #}
{% macro generate_class_member_h(member, tab) -%}
{{tab}}/// @brief {{ member.description }}
{{tab}}{%- if member.const %}const {% endif -%}
{%- if member.volatile %}volatile {% endif -%}
{{ member.type }}{{ member.indirection }} {{ member.name }}{ {{ member.default }} };
{%- endmacro %}


{# =================== Class Method H =================== #}
{% macro generate_class_method_h(method, tab) -%}
{{tab}}/// @brief {{ method.description }}
{% for p in method.params %}
{{tab}}/// @param {{ p.name }} {{ p.description }}
{% endfor %}
{{tab}}{%- if method.const %}const {% endif -%}
{%- if method.volatile %}volatile {% endif -%}
{{ method.type }}{{ method.indirection }} {{ method.name }}(
{%- for p in method.params -%}
{%- if p.const %}const {% endif -%}
{%- if p.volatile %}volatile {% endif -%}
{{ p.type }}{{ p.indirection }} {{ p.name }}{% if not loop.last %}, {% endif %}
{%- endfor -%}
)
{%- if method.immutable %} const{% endif -%}
{%- if method.noexcept %} noexcept{% endif -%}
{%- if method.override %} override{% endif %};
{%- endmacro %}


{# =================== Class Method CPP =================== #}
{% macro generate_class_method_cpp(method, modelname, tab) -%}
/// @brief {{ method.description }}
{% for p in method.params %}
/// @param {{ p.name }} {{ p.description }}
{% endfor %}
{%- if method.const %}const {% endif -%}
{%- if method.volatile %}volatile {% endif -%}
{{ method.type }}{{ method.indirection }} {{ modelname }}::{{ method.name }}(
{%- for p in method.params -%}
{%- if p.const %}const {% endif -%}
{%- if p.volatile %}volatile {% endif -%}
{{ p.type }}{{ p.indirection }} {{ p.name }}{% if not loop.last %}, {% endif %}
{%- endfor -%}
)
{%- if method.immutable %} const{% endif -%}
{%- if method.noexcept %} noexcept{% endif %}

{
{{tab}}// TODO: implement
}
{%- endmacro %}


{# =================== Class Constructor H =================== #}
{% macro generate_class_constructor_h(constructor, modelname, tab) -%}
{{tab}}/// @brief {{ constructor.description }}
{% for p in constructor.params %}
{{tab}}/// @param {{ p.name }} {{ p.description }}
{% endfor %}
{{tab}}{{ modelname }}(
{%- for p in constructor.params -%}
{%- if p.const %}const {% endif -%}
{%- if p.volatile %}volatile {% endif -%}
{{ p.type }}{{ p.indirection }} {{ p.name }}{% if not loop.last %}, {% endif %}
{%- endfor -%}
)
{%- if constructor.noexcept %} noexcept{% endif -%};
{%- endmacro %}


{# =================== Class Constructor CPP =================== #}
{% macro generate_class_constructor_cpp(constructor, modelname, tab) -%}
/// @brief {{ constructor.description }}
{% for p in constructor.params %}
/// @param {{ p.name }} {{ p.description }}
{% endfor %}
{{ modelname }}::{{ modelname }}(
{%- for p in constructor.params -%}
{%- if p.const %}const {% endif -%}
{%- if p.volatile %}volatile {% endif -%}
{{ p.type }}{{ p.indirection }} {{ p.name }}{% if not loop.last %}, {% endif %}
{%- endfor -%}
)
{%- if constructor.noexcept %} noexcept{% endif %}

{
{{tab}}// TODO: implement
}
{%- endmacro %}


{# =================== Class Destructor H =================== #}
{% macro generate_class_destructor_h(modelname, tab) -%}
{{tab}}/// @brief Destructor of {{ modelname }}
{{tab}}~{{ modelname }}() noexcept;
{%- endmacro %}


{# =================== Class Destructor CPP =================== #}
{% macro generate_class_destructor_cpp(modelname, tab) -%}
/// @brief Destructor of {{ modelname }}
{{ modelname }}::~{{ modelname }}() noexcept
{
{{tab}}// TODO: implement
}
{%- endmacro %}


{# =================== Interface Method H =================== #}
{% macro generate_interface_method_h(method, tab) -%}
{{tab}}/// @brief {{ method.description }}
{% for p in method.params %}
{{tab}}/// @param {{ p.name }} {{ p.description }}
{% endfor %}
{{tab}}{%- if true %}virtual {% endif -%}
{%- if method.const %}const {% endif -%}
{%- if method.volatile %}volatile {% endif -%}
{{ method.type }}{{ method.indirection }} {{ method.name }}(
{%- for p in method.params -%}
{%- if p.const %}const {% endif -%}
{%- if p.volatile %}volatile {% endif -%}
{{ p.type }}{{ p.indirection }} {{ p.name }}{% if not loop.last %}, {% endif %}
{%- endfor -%}
)
{%- if method.immutable %} const{% endif -%}
{%- if method.noexcept %} noexcept{% endif %} = 0;
{%- endmacro %}


{# =================== Interface Constructor H =================== #}
{% macro generate_interface_constructor_h(modelname, tab) -%}
{{tab}}/// @brief Default constructor of {{ modelname }}
{{tab}}{{ modelname }}() = default;
{%- endmacro %}


{# =================== Interface Destructor H =================== #}
{% macro generate_interface_destructor_h(modelname, tab) -%}
{{tab}}/// @brief Virtual destructor of {{ modelname }}
{{tab}}virtual ~{{ modelname }}() noexcept = default;
{%- endmacro %}
